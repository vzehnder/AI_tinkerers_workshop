{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"],
      "autoApprove": [
        "take_snapshot",
        "take_screenshot",
        "navigate_page",
        "click",
        "fill",
        "wait_for",
        "evaluate_script",
        "press_key",
        "list_pages",
        "new_page",
        "select_page",
        "list_console_messages",
        "get_console_message",
        "list_network_requests",
        "get_network_request",
        "handle_dialog"
      ],
      "disabled": false
    }
  }
}